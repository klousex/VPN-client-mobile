# Copy this file to android/signing.properties and fill in real values.
# The release build will remain unsigned until these values are provided.

VPN_CLIENT_RELEASE_STORE_FILE=keystore\vpn-client-release.jks
VPN_CLIENT_RELEASE_STORE_PASSWORD=change-me
VPN_CLIENT_RELEASE_KEY_ALIAS=vpn-client
VPN_CLIENT_RELEASE_KEY_PASSWORD=change-me
